# Airtable personal access token — scope: data.records:read, access: Existable base only.
# Copy this file to .env and fill in the real value. Never commit .env.
AIRTABLE_TOKEN=your_airtable_personal_access_token_here
# Optional overrides (defaults are baked into api/feed.js):
# AIRTABLE_BASE=appJTn7cHXFraJfx1
# AIRTABLE_TABLE=tblgqzcrj0SSOHCQs
